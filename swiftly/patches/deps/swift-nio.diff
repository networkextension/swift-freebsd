 FTS *CNIOOpenBSD_fts_open(char * const *path_argv, int options, int (*compar)(const FTSENT **, const FTSENT **)) {
+#if defined(__FreeBSD__)
+    // FreeBSD's fts_open comparator takes `const FTSENT *const *`; cast to match.
+    return fts_open(path_argv, options, (int (*)(const FTSENT * const *, const FTSENT * const *))compar);
